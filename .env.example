# Focale backend development environment template.
# Copy to .env for local development and replace placeholders before running the app.
# Never commit real .env files or production secrets.

# Required core settings
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://dev_user:dev_password@localhost:5432/focale_dev
CORS_ORIGIN=http://localhost:8080

# Required Firebase settings when STORAGE_PROVIDER=firebase
FIREBASE_PROJECT_ID=replace-with-firebase-project-id
FIREBASE_STORAGE_BUCKET=replace-with-firebase-storage-bucket
# Optional Firebase service account JSON for deployed/cloud runtimes only.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"replace-with-project-id"}

# Email provider selection: sendgrid (default) or resend
# EMAIL_PROVIDER=sendgrid

# Shared sender identity (used by whichever provider is active).
# Falls back to SENDGRID_FROM_* below if unset.
# EMAIL_FROM_EMAIL=noreply@example.invalid
# EMAIL_FROM_NAME=Focale Events

# Optional SendGrid email delivery (used when EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=replace-with-sendgrid-api-key
# SENDGRID_WEBHOOK_PUBLIC_KEY=replace-with-sendgrid-webhook-public-key
# SENDGRID_FROM_EMAIL=noreply@example.invalid
# SENDGRID_FROM_NAME=Focale Events

# Optional Resend email delivery (used when EMAIL_PROVIDER=resend)
# RESEND_API_KEY=replace-with-resend-api-key
# RESEND_WEBHOOK_SECRET=whsec_replace-with-resend-webhook-signing-secret

# Storage provider: firebase or r2
STORAGE_PROVIDER=firebase

# Optional public forms base URL used in email links
# PUBLIC_FORMS_URL=https://forms.example.invalid

# Base URL for the admin app. Firebase Console > Authentication > Templates >
# "Customize action URL" must point at ${ADMIN_APP_URL}/auth/action so reset
# links land on our in-app handler instead of Firebase's hosted action page.
ADMIN_APP_URL=http://localhost:8080

# Required only when STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=replace-with-r2-account-id
# R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
# R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
# R2_BUCKET=replace-with-r2-bucket-name
# R2_PUBLIC_URL=https://assets.example.invalid

# Realtime / Server-Sent Events
REALTIME_DISABLED=false
SSE_HEARTBEAT_MS=25000
SSE_CLIENT_RETRY_MS=15000

# Public abstracts rate limits
ABSTRACTS_SUBMIT_RATE_LIMIT_MAX=60
ABSTRACTS_EDIT_RATE_LIMIT_MAX=30
ABSTRACTS_READ_RATE_LIMIT_MAX=120
ABSTRACTS_RATE_LIMIT_WINDOW=1 minute

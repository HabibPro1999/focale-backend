{
  "name": "@app/worker",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch --conditions=@app/source -r @swc-node/register src/main.ts",
    "requeue-skipped-abstract-emails": "node --conditions=@app/source -r @swc-node/register src/scripts/requeue-skipped-abstract-emails.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@app/contracts": "workspace:*",
    "@app/db": "workspace:*",
    "@app/integrations": "workspace:*",
    "@app/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@pdf-lib/fontkit": "1.1.1",
    "dejavu-fonts-ttf": "2.37.3",
    "pdf-lib": "1.17.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@swc-node/register": "^1.10.9",
    "@swc/core": "^1.10.1",
    "@types/node": "^24.0.0",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.2.4"
  }
}

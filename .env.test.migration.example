# Focale backend migration test environment template.
# Copy to .env.test.migration only for disposable migration smoke tests.
# Tests never load .env. The database must be safe to create/drop/migrate.

NODE_ENV=test
ALLOW_DB_TESTS=1

# Must point to a disposable database whose name contains "test" or "ci".
# Placeholder only; replace locally/CI with a non-production Cockroach/PostgreSQL URL.
TEST_MIGRATION_DATABASE_URL=postgresql://test_user:test_password@localhost:26257/focale_migration_test?sslmode=disable

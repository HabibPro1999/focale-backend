# Focale backend DB test environment template.
# Copy to .env.test.db only for disposable local/CI DB integration tests.
# Tests never load .env. Do not use production or shared development databases.

NODE_ENV=test
ALLOW_DB_TESTS=1

# Must point to a disposable database whose name contains "test" or "ci".
# Placeholder only; replace locally/CI with a non-production Cockroach/PostgreSQL URL.
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:26257/focale_test?sslmode=disable

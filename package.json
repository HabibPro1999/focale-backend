{
  "name": "focale-os",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "dev": "pnpm --filter @app/api dev",
    "dev:worker": "pnpm --filter @app/worker dev"
  }
}

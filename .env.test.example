# Focale backend unit test environment template.
# Copy to .env.test only when unit tests need local-safe overrides.
# Unit tests never load .env and always use Prisma/Firebase/SendGrid mocks.
# Values here must stay dummy/local and must not contain production credentials.

NODE_ENV=test
PORT=0
CORS_ORIGIN=http://localhost:8080

# Unit tests force a dummy DATABASE_URL in code; do not put real DB URLs here.

# Safe test Firebase/storage defaults
FIREBASE_PROJECT_ID=test-project
FIREBASE_STORAGE_BUCKET=test-bucket
STORAGE_PROVIDER=firebase

# Safe test email defaults. Do not use real SendGrid credentials in tests.
SENDGRID_FROM_EMAIL=noreply@example.test
SENDGRID_FROM_NAME=Test Sender

# Safe test public URL and realtime defaults
PUBLIC_FORMS_URL=http://localhost:8080/forms
REALTIME_DISABLED=false
SSE_HEARTBEAT_MS=25000
SSE_CLIENT_RETRY_MS=15000

# Public abstracts rate limits for tests
ABSTRACTS_SUBMIT_RATE_LIMIT_MAX=1000
ABSTRACTS_EDIT_RATE_LIMIT_MAX=1000
ABSTRACTS_READ_RATE_LIMIT_MAX=1000
ABSTRACTS_RATE_LIMIT_WINDOW=1 minute
